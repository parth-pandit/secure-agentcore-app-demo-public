# CloudFormation parameter files with actual values (DO NOT COMMIT)
# These files contain sensitive information like client IDs, secrets, and tenant IDs
# The .template versions are safe to commit as they contain only REPLACE_WITH placeholders
infrastructure/cloudformation/parameters/dev-parameters.json
infrastructure/cloudformation/parameters/staging-parameters.json
infrastructure/cloudformation/parameters/prod-parameters.json
infrastructure/cloudformation/agentcore-gateway-parameters.json

# Keep template files for reference (with REPLACE_WITH placeholders)
!infrastructure/cloudformation/parameters/*-parameters.json.template
!infrastructure/cloudformation/agentcore-gateway-parameters.json.template

# Kiro specs and settings
.kiro/settings/mcp.json
.kiro/specs/*/design.md
.kiro/specs/*/IMPLEMENTATION_SUMMARY.md
.kiro/specs/*/requirements.md
.kiro/specs/*/tasks.md
.kiro/specs/*/.config.kiro
.kiro/specs/*/bugfix.md
infrastructure/scripts/quick-command-reference.txt

# Multi-region deployment config (contains account-specific values)
infrastructure/deploy-config-multi-region.sh
infrastructure/cloudformation/parameters/dev-parameters-multi-region.json
infrastructure/cloudformation/parameters/dev-parameters.json
