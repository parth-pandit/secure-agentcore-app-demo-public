# AWS Region Configuration
# ========================
# This project is region-agnostic. Set AWS_REGION to your target region.
# All scripts, Lambda functions, and deployment tools will use this value.
#
# Supported regions: us-east-1, us-west-2, eu-west-1, ap-southeast-1, etc.
# Default: us-west-2 (if not set)

AWS_REGION=us-west-2

# AWS Account Configuration
# ========================
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID

# S3 Bucket for Lambda Code
# ========================
S3_BUCKET=your-s3-bucket-name

# CloudFormation Stack Configuration
# ========================
STACK_NAME=dev-orders-api
ENVIRONMENT=dev

# AgentCore Configuration
# ========================
# Agent Runtime ARN (will be constructed using AWS_REGION)
# Format: arn:aws:bedrock-agentcore:${AWS_REGION}:${AWS_ACCOUNT_ID}:runtime/RUNTIME_ID
AGENT_RUNTIME_ID=YOUR_RUNTIME_ID

# Bedrock Model Configuration
# ========================
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
MODEL_TEMPERATURE=0.2

# OAuth Configuration
# ========================
# OAuth callback server URL (will be constructed using AWS_REGION)
# Format: https://YOUR_API_GATEWAY_ID.execute-api.${AWS_REGION}.amazonaws.com
OAUTH_CALLBACK_SERVER_URL=https://YOUR_API_GATEWAY_ID.execute-api.${AWS_REGION}.amazonaws.com
OAUTH_CALLBACK_TABLE=agentcore-oauth-callback

# Lambda Configuration
# ========================
LAMBDA_NAME=agentcore-proxy-strands-sonnet45
ALLOW_ORIGIN=*
LOG_LEVEL=INFO

# Gateway Configuration
# ========================
GATEWAY_SECRET_NAME=agentcore/gateway-authcode
GATEWAY_TOOLS_ENABLED=true
GATEWAY_PROTOCOL_VERSION=2025-11-25

# Monitoring Configuration
# ========================
# SNS Topic ARN for alerts (will be constructed using AWS_REGION)
# Format: arn:aws:sns:${AWS_REGION}:${AWS_ACCOUNT_ID}:alerts
SNS_TOPIC_ARN=arn:aws:sns:${AWS_REGION}:${AWS_ACCOUNT_ID}:alerts
