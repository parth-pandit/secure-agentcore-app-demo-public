# Frontend Application Configuration
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ============================================
# Azure AD Authentication Configuration
# ============================================
# Azure AD application (client) ID
# Format: UUID (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# Get this from Azure Portal > App Registrations > Your App > Overview
MSAL_CLIENT_ID=f8xxxxxx-9xxa-4xx9-8xx7-axxxxxxxxx1a

# Azure AD authority URL including tenant ID
# Format: https://login.microsoftonline.com/{tenant-id}
# Get tenant ID from Azure Portal > Azure Active Directory > Overview
MSAL_AUTHORITY=https://login.microsoftonline.com/d9xxxxxxa-fxx1-4xx9-axxd-0xxxxxxxxx97

# OAuth redirect URI
# Format: https://your-domain.com/ or http://localhost:3000/ for local dev
# IMPORTANT: This URI must be registered in Azure AD App Registration > Authentication
REDIRECT_URI=https://dxxxxxxxxxevy.cloudfront.net/

# ============================================
# API Endpoint Configuration
# ============================================
# AgentCore REST API endpoint
# Format: https://your-api.execute-api.region.amazonaws.com/invoke
AGENTCORE_ENDPOINT=https://oxxxxxx2e.execute-api.us-west-2.amazonaws.com/invoke

# WebSocket signing endpoint (optional)
# Format: https://your-ws-signer.execute-api.region.amazonaws.com/sign
# Leave empty if not using WebSocket connections
WS_SIGN_ENDPOINT=

# ============================================
# Security Notes
# ============================================
# - Never commit actual credentials to version control
# - Use different values for dev, staging, and production environments
# - Rotate credentials regularly
# - Keep .env.local in .gitignore
